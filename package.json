{
  "name": "neuroboost",
  "productName": "NeuroBoost",
  "version": "0.1.0",
  "description": "PWA gamifiée pour cerveaux TDAH — vaincre l'inertie une mission à la fois",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cf": "wrangler pages dev -- npm run dev",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist --project-name=neuroboost",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@supabase/supabase-js": "^2.108.2",
    "localforage": "^1.10.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.1",
    "sharp": "^0.35.2",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.0.0"
  }
}
